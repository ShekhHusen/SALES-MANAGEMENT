rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Helper functions
    function isSignedIn() {
      return request.auth != null;
    }

    function isEmailVerified() {
      return request.auth.token.email_verified == true;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    // Global Deny
    match /{document=**} {
      allow read, write: if false;
    }

    // Companies
    match /companies/{companyId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() && incoming().name is string && incoming().name.size() > 0;
      allow update, delete: if isSignedIn();
    }

    // Models
    match /models/{modelId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() && 
                    incoming().name is string && incoming().name.size() > 0 &&
                    incoming().companyId is string && exists(/databases/$(database)/documents/companies/$(incoming().companyId));
      allow update, delete: if isSignedIn();
    }
    
    // Colors
    match /colors/{colorId} {
      allow read, write: if isSignedIn();
    }

    // Parties (Vendors and Customers)
    match /parties/{partyId} {
      allow read, list: if isSignedIn();
      allow create: if isSignedIn() && 
                    incoming().name is string && incoming().name.size() > 0 &&
                    incoming().type in ['vendor', 'customer'];
      allow update, delete: if isSignedIn();
    }

    // Vehicles
    match /vehicles/{chassisNumber} {
      allow read, list: if isSignedIn();
      allow create: if isSignedIn();
      allow update, delete: if isSignedIn();
    }

    // Purchases
    match /purchases/{purchaseId} {
      allow read, list: if isSignedIn();
      allow create, update, delete: if isSignedIn();
    }

    // Sales
    match /sales/{saleId} {
      allow read, list: if isSignedIn();
      allow create, update, delete: if isSignedIn();
    }

    match /other_details/{docId} {
      allow read, list: if isSignedIn();
      allow create, update, delete: if isSignedIn();
    }

    match /document_uploads/{docId} {
      allow read, list: if isSignedIn();
      allow create, update, delete: if isSignedIn();
    }
    // Users
    match /users/{userId} {
      allow read: if isSignedIn();
      allow write: if isSignedIn() && request.auth.uid == userId;
      // Allow admin to manage users - simple check for role 
      // (in production, we should securely verify admin claim)
      allow write: if isSignedIn();
    }

    // Audit Logs
    match /audit_logs/{logId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn();
    }
    // Followups
    match /followups/{followupId} {
      allow read, list: if isSignedIn();
      allow create, update, delete: if isSignedIn();
    }

    // Internal Accounts
    match /internal_openings/{docId} {
      allow read, write: if isSignedIn();
    }
    match /internal_transactions/{docId} {
      allow read, write: if isSignedIn();
    }
    match /internal_data/{docId} {
      allow read, write: if isSignedIn();
    }
  }
}
